# =============================================================================
# Humaniza RJ — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git!
# =============================================================================

# --- Banco de Dados (Docker local) ---
DB_USERNAME=humaniza
DB_PASSWORD=troque_esta_senha_aqui

# --- Banco de Dados (Supabase — produção) ---
# Descomente e preencha ao usar Supabase:
# DATABASE_URL=jdbc:postgresql://db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=sua_senha_supabase

# --- JWT ---
# Gere um segredo seguro: openssl rand -base64 64
JWT_SECRET=troque_este_secret_por_um_valor_seguro_em_base64

# --- Usuário Admin 1 (obrigatório) ---
ADMIN1_EMAIL=caissa@humaniza.com
ADMIN1_NOME=Caissa Humaniza
ADMIN1_PASSWORD=troque_esta_senha_aqui

# --- Usuário Admin 2 (opcional — deixe em branco para não criar) ---
ADMIN2_EMAIL=
ADMIN2_NOME=
ADMIN2_PASSWORD=
